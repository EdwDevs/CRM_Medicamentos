rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Esta app no implementa Firebase Auth en frontend;
    // por eso permitimos acceso abierto para evitar bloqueos de lectura/escritura.
    function canAccessPayments() {
      return true;
    }

    match /payments/{paymentId} {
      allow read, write: if canAccessPayments();
    }

    match /cash_movements/{movementId} {
      allow read, write: if canAccessPayments();
    }
  }
}
