rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function canAccessPayments() {
      return request.auth != null;
    }

    match /payments/{paymentId} {
      allow read, write: if canAccessPayments();
    }

    match /cash_movements/{movementId} {
      allow read, write: if canAccessPayments();
    }
  }
}
